<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<VBox alignment="CENTER"
      prefHeight="455.0"
      prefWidth="626.0"
      spacing="20.0"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.miracosta.cs112.controllers.MainController">

    <padding>
        <Insets bottom="20.0"
                left="20.0"
                right="20.0"
                top="20.0" />
    </padding>

    <Label fx:id="welcomeText" />

    <Button onAction="#onHelloButtonClick"
            text="Hello!" />

    <!-- CONTENT AREA (opens above buttons) -->
    <AnchorPane fx:id="contentPane"
                prefHeight="200.0"
                VBox.vgrow="ALWAYS" />

    <!-- BUTTON BAR -->
    <HBox prefHeight="130.0"
          prefWidth="428.0"
          spacing="10">

        <children>

            <Rectangle fx:id="square1"
                       onMouseClicked="#handleSquareClick"
                       arcHeight="5.0"
                       arcWidth="5.0"
                       fill="DODGERBLUE"
                       height="126.0"
                       stroke="BLACK"
                       strokeType="INSIDE"
                       width="131.0" />

            <Rectangle fx:id="square2"
                       onMouseClicked="#handleSquareClick"
                       arcHeight="5.0"
                       arcWidth="5.0"
                       fill="DODGERBLUE"
                       height="126.0"
                       stroke="BLACK"
                       strokeType="INSIDE"
                       width="131.0" />

            <Rectangle fx:id="square3"
                       onMouseClicked="#handleSquareClick"
                       arcHeight="5.0"
                       arcWidth="5.0"
                       fill="DODGERBLUE"
                       height="126.0"
                       stroke="BLACK"
                       strokeType="INSIDE"
                       width="131.0" />

        </children>

    </HBox>

</VBox>